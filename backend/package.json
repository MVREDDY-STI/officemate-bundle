{
  "name": "officemate-backend",
  "version": "1.0.0",
  "description": "SOLUM Officemate backend — Bun.js + PostgreSQL + WebSockets",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "pg": "^8.13.3",
    "jsonwebtoken": "^9.0.2",
    "@types/pg": "^8.11.11",
    "@types/jsonwebtoken": "^9.0.9"
  },
  "devDependencies": {
    "bun-types": "^1.3.10"
  }
}
